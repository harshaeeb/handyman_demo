---
// src/layouts/Base.astro — Handyman demo with SEO: Plumber schema, OG, canonical
import "../styles/global.css";
import { site } from "../config/site";
import { generateBrandCssVars } from "../utils/palette";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const brandVars = generateBrandCssVars(site.brandColor);

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://donerighthandyman-demo.pages.dev");
const ogImage = new URL("/og-default.png", Astro.site ?? "https://donerighthandyman-demo.pages.dev");

const schema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: site.business,
  url: (Astro.site ?? "https://donerighthandyman-demo.pages.dev").toString().replace(/\/$/, ""),
  description: site.tagline,
  telephone: site.phone,
  email: site.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.split(",")[0]?.trim(),
    addressLocality: site.city,
    addressRegion: site.state,
    postalCode: site.zip,
    addressCountry: "US",
  },
  areaServed: site.serviceAreas,
  openingHours: ["Mo-Sa 09:00-19:00", "Su 09:00-17:00"],
  sameAs: [site.googleReviewLink],
  aggregateRating: site.googleReviewCount
    ? {
        "@type": "AggregateRating",
        ratingValue: site.googleRating,
        reviewCount: site.googleReviewCount,
      }
    : undefined,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.toString()} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage.toString()} />
    <meta property="og:site_name" content={site.business} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.toString()} />

    <meta name="author" content={site.business} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />

    <style define:vars={brandVars}>
      :root {
        --brand-50:  var(--brand50);
        --brand-100: var(--brand100);
        --brand-200: var(--brand200);
        --brand-300: var(--brand300);
        --brand-400: var(--brand400);
        --brand-500: var(--brand500);
        --brand-600: var(--brand600);
        --brand-700: var(--brand700);
        --brand-800: var(--brand800);
        --brand-900: var(--brand900);
        --brand-950: var(--brand950);
        --brand:           var(--brand600);
        --brand-dark:      var(--brand800);
        --brand-surface:   var(--brand50);
        --brand-surface-strong: var(--brand100);
      }
    </style>
  </head>
  <body class={`min-h-screen flex flex-col font-sans text-slate-800 antialiased round-${site.theme?.roundness ?? "lg"}`}>
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("revealed");
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll("[data-reveal],[data-reveal-stagger]").forEach((el) => io.observe(el));
    </script>
  </body>
</html>
