---
// src/components/ServicesGrid.astro — Gen Z redesign: tilt cards, sticker
// number badges, pop-shadow depth. Each service's photo still comes from
// `service.image` in site.ts (see resolveImage) — same placeholder
// convention as Hero.astro when no file exists yet.
//
// Card layout is name → square photo → details (rather than photo-first).
// The source photos client-supplied are mostly portrait/near-square, not
// wide landscape — the previous h-36 full-width strip cropped them hard.
// A square frame crops far less and reads consistently regardless of the
// source's native aspect ratio.
import { site } from "../config/site";
import { resolveImage } from "../utils/resolveImage";

interface Props {
  compact?: boolean;
  hideHeading?: boolean;
}
const { compact = false, hideHeading = false } = Astro.props;

const displayServices = compact ? site.services.slice(0, 6) : site.services;
---

<section class="relative py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    {!hideHeading && (
      <div class="text-center mb-14" data-reveal>
        <span class="sticker inline-block text-xs font-bold text-[var(--brand-600)] uppercase tracking-widest mb-3 bg-[var(--brand-50)] border-2 border-[var(--brand-100)] rounded-full px-3 py-1">
          What We Do
        </span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900">Services built for modern life</h2>
        <p class="mt-3 text-slate-500 max-w-xl mx-auto">
          {site.yearsInBusiness}+ years keeping homes in {site.serviceAreas.slice(0,3).join(", ")} in perfect shape.
        </p>
      </div>
    )}

    <div class={`grid gap-4 ${compact ? "sm:grid-cols-2 lg:grid-cols-3" : "sm:grid-cols-2 lg:grid-cols-4"}`} data-reveal-stagger>
      {displayServices.map((service, i) => {
        const img = resolveImage(service.image);
        return (
          <a
            href={`/services/${service.slug}`}
            data-tilt
            class="pop-shadow bg-white border-2 border-slate-900/5 rounded-[1.5rem] overflow-hidden group block"
          >
            <div class="px-5 pt-5 pb-4 flex items-center justify-between gap-2">
              <h3 class="font-display font-bold text-slate-900 text-base group-hover:text-[var(--brand-600)] transition-colors">{service.name}</h3>
              <span class="sticker flex-shrink-0 w-8 h-8 rounded-full bg-[var(--brand-50)] flex items-center justify-center text-xs font-black text-[var(--brand-600)] border-2 border-[var(--brand-100)]">
                {String(i + 1).padStart(2, "0")}
              </span>
            </div>

            {img ? (
              <div class="aspect-square overflow-hidden bg-slate-100">
                <img
                  src={img}
                  alt={service.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width="500"
                  height="500"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="aspect-square flex items-center justify-center relative overflow-hidden bg-gradient-to-br from-[var(--brand-50)] to-[var(--brand-100)]">
                <p class="text-xs text-[var(--brand-400)] text-center px-4">[ {service.name} photo goes here ]</p>
              </div>
            )}

            <div class="p-5">
              <p class="text-sm text-slate-500 leading-relaxed line-clamp-2">{service.shortDescription}</p>
              <div class="mt-4 flex items-center gap-1 text-xs font-semibold text-[var(--brand-600)] group-hover:gap-2 transition-all">
                Learn more
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" fill="currentColor" class="w-3 h-3">
                  <path fill-rule="evenodd" d="M2 6a.75.75 0 0 1 .75-.75h5.44L6.47 3.03a.75.75 0 1 1 1.06-1.06l3 3a.75.75 0 0 1 0 1.06l-3 3a.75.75 0 1 1-1.06-1.06l1.72-1.72H2.75A.75.75 0 0 1 2 6Z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    {compact && site.services.length > 6 && (
      <div class="mt-10 text-center" data-reveal>
        <a href="/services" class="pop-shadow inline-flex items-center gap-2 bg-white border-2 border-slate-900/5 px-6 py-3 rounded-full text-sm font-bold text-slate-900 hover:-translate-y-0.5 transition-transform">
          View all {site.services.length} services
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
