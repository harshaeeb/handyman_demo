---
// src/components/ServicesGrid.astro — Gen Z bento grid with handyman icons
import { site } from "../config/site";
import { resolveImage } from "../utils/resolveImage";

interface Props {
  compact?: boolean;
  hideHeading?: boolean;
}
const { compact = false, hideHeading = false } = Astro.props;

const displayServices = compact ? site.services.slice(0, 6) : site.services;

// Handyman service icons (SVG paths)
const icons: Record<string, string> = {
  "general-repairs":    `<path d="M3.5 2A1.5 1.5 0 0 0 2 3.5v2.879a1.5 1.5 0 0 0 .44 1.06L7.845 12.9a2.5 2.5 0 0 1 0 3.536l.707.707a2.5 2.5 0 0 0 3.536 0l3.535-3.536a2.5 2.5 0 0 0 0-3.535L10.56 5.44A1.5 1.5 0 0 0 9.5 5H6.621a1.5 1.5 0 0 1-1.06-.44L4.5 3.5V2h-1Zm0 0" fill="currentColor"/>`,
  "tv-mounting":        `<path d="M1.5 2.5A1.5 1.5 0 0 1 3 1h10a1.5 1.5 0 0 1 1.5 1.5v7A1.5 1.5 0 0 1 13 11H8.75v1.5H11a.75.75 0 0 1 0 1.5H5a.75.75 0 0 1 0-1.5h2.25V11H3A1.5 1.5 0 0 1 1.5 9.5v-7ZM3 2.5v7h10v-7H3Z" fill="currentColor"/>`,
  "furniture-assembly": `<path d="M1 3.5A1.5 1.5 0 0 1 2.5 2h11A1.5 1.5 0 0 1 15 3.5V5h.5a.5.5 0 0 1 0 1H15v5h.5a.5.5 0 0 1 0 1H15v1.5A1.5 1.5 0 0 1 13.5 14h-11A1.5 1.5 0 0 1 1 12.5V11H.5a.5.5 0 0 1 0-1H1V5H.5a.5.5 0 0 1 0-1H1V3.5zm1.5 0v9h11v-9h-11z" fill="currentColor"/>`,
  "painting":           `<path d="M11.898 7.674c.088.196.133.412.102.645-.07.53-.555.981-1.219.981H9.25a.75.75 0 0 0 0 1.5h1.531c1.197 0 2.281-.844 2.493-2.028.107-.594-.014-1.178-.304-1.672L11.898 7.674ZM9.25 4.5a.75.75 0 0 0 0 1.5H10a.75.75 0 0 0 0-1.5H9.25Z" fill="currentColor"/><path fill-rule="evenodd" d="M2 3.25C2 2.56 2.56 2 3.25 2h.5A2.75 2.75 0 0 1 6.5 4.75v.5A2.25 2.25 0 0 1 4.25 7.5H4v1.5h.25A3.75 3.75 0 0 0 8 5.25v-.5A4.25 4.25 0 0 0 3.75.5h-.5A2.75 2.75 0 0 0 .5 3.25v9.5A2.75 2.75 0 0 0 3.25 15.5h9.5A2.75 2.75 0 0 0 15.5 12.75v-1.5a.75.75 0 0 0-1.5 0v1.5c0 .69-.56 1.25-1.25 1.25h-9.5C2.56 14 2 13.44 2 12.75V3.25Z" clip-rule="evenodd" fill="currentColor"/>`,
  "pressure-washing":   `<path d="M8.75 3.75a.75.75 0 0 0-1.5 0v3.5h-3.5a.75.75 0 0 0 0 1.5h3.5v3.5a.75.75 0 0 0 1.5 0V8.75h3.5a.75.75 0 0 0 0-1.5h-3.5V3.75Z" fill="currentColor"/>`,
  "smart-home-setup":   `<path fill-rule="evenodd" d="M14.447 3.026a.75.75 0 0 1 .527.921l-4.5 16.5a.75.75 0 0 1-1.448-.394l4.5-16.5a.75.75 0 0 1 .921-.527ZM6.166 5.106a.75.75 0 0 1 0 1.06L3.293 9.039l2.873 2.873a.75.75 0 1 1-1.06 1.06L1.666 9.599a.75.75 0 0 1 0-1.06l3.44-3.433a.75.75 0 0 1 1.06 0Zm7.668 0a.75.75 0 0 1 1.06 0l3.44 3.433a.75.75 0 0 1 0 1.06l-3.44 3.433a.75.75 0 0 1-1.06-1.06l2.873-2.873-2.873-2.873a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" fill="currentColor"/>`,
  "door-window-repair": `<path fill-rule="evenodd" d="M3 2.25a.75.75 0 0 0 0 1.5v11.25h-.75a.75.75 0 0 0 0 1.5H15a.75.75 0 0 0 0-1.5h-.75V3.75a.75.75 0 0 0 0-1.5H3Zm6.75 11.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0ZM6 7.5a.75.75 0 0 1 .75-.75h2.5a.75.75 0 0 1 0 1.5h-2.5A.75.75 0 0 1 6 7.5Z" clip-rule="evenodd" fill="currentColor"/>`,
  "flooring":           `<path fill-rule="evenodd" d="M.75 2a.75.75 0 0 0 0 1.5h14.5a.75.75 0 0 0 0-1.5H.75ZM.75 6.5a.75.75 0 0 0 0 1.5h14.5a.75.75 0 0 0 0-1.5H.75ZM.75 11a.75.75 0 0 0 0 1.5h14.5a.75.75 0 0 0 0-1.5H.75Z" clip-rule="evenodd" fill="currentColor"/>`,
};

const gradients = [
  "linear-gradient(135deg, #c2410c 0%, #ea580c 100%)",
  "linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%)",
  "linear-gradient(135deg, #065f46 0%, #10b981 100%)",
  "linear-gradient(135deg, #7c2d12 0%, #dc2626 100%)",
  "linear-gradient(135deg, #1e1b4b 0%, #7c3aed 100%)",
  "linear-gradient(135deg, #0c4a6e 0%, #0ea5e9 100%)",
  "linear-gradient(135deg, #3f3f46 0%, #71717a 100%)",
  "linear-gradient(135deg, #14532d 0%, #22c55e 100%)",
];
---

<section class="relative py-20" style="background: #0f0e0d;">
  <!-- Subtle section separator -->
  <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    {!hideHeading && (
      <div class="text-center mb-14" data-reveal>
        <span class="inline-block text-xs font-bold text-[var(--brand-400)] uppercase tracking-widest mb-3 border border-[var(--brand-800)] rounded-full px-3 py-1" style="background: rgba(234,88,12,0.1);">
          What We Do
        </span>
        <h2 class="text-3xl sm:text-4xl font-black text-white">Services built for modern life</h2>
        <p class="mt-3 text-white/50 max-w-xl mx-auto">
          {site.yearsInBusiness}+ years keeping homes in {site.serviceAreas.slice(0,3).join(", ")} in perfect shape.
        </p>
      </div>
    )}

    <div class={`grid gap-4 ${compact ? "sm:grid-cols-2 lg:grid-cols-3" : "sm:grid-cols-2 lg:grid-cols-4"}`} data-reveal-stagger>
      {displayServices.map((service, i) => {
        const icon = icons[service.slug] ?? icons["general-repairs"];
        const grad = gradients[i % gradients.length];
        const img = resolveImage(service.image);
        return (
          <a
            href={`/services/${service.slug}`}
            class="glass bento-glow card-lift rounded-[var(--radius,1.25rem)] overflow-hidden group block"
            style="border: 1px solid rgba(255,255,255,0.07);"
          >
            {img ? (
              <div class="h-36 overflow-hidden">
                <img src={img} alt={service.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="400" height="200" />
              </div>
            ) : (
              <div class="h-36 flex items-center justify-center relative overflow-hidden noise-overlay" style={`background: ${grad};`}>
                <div class="absolute inset-0 opacity-10 grid-overlay"></div>
                <div class="absolute top-3 right-3 w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-black text-white/70" style="background: rgba(0,0,0,0.3);">
                  {String(i + 1).padStart(2, "0")}
                </div>
                <div class="relative z-10 w-12 h-12 rounded-2xl flex items-center justify-center text-white" style="background: rgba(255,255,255,0.15);">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="w-6 h-6 text-white" set:html={icon}></svg>
                </div>
              </div>
            )}

            <div class="p-5">
              <h3 class="font-bold text-white text-base group-hover:text-[var(--brand-300)] transition-colors">{service.name}</h3>
              <p class="mt-1.5 text-sm text-white/50 leading-relaxed line-clamp-2">{service.shortDescription}</p>
              <div class="mt-4 flex items-center gap-1 text-xs font-semibold text-[var(--brand-400)] group-hover:gap-2 transition-all">
                Learn more
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" fill="currentColor" class="w-3 h-3">
                  <path fill-rule="evenodd" d="M2 6a.75.75 0 0 1 .75-.75h5.44L6.47 3.03a.75.75 0 1 1 1.06-1.06l3 3a.75.75 0 0 1 0 1.06l-3 3a.75.75 0 1 1-1.06-1.06l1.72-1.72H2.75A.75.75 0 0 1 2 6Z" clip-rule="evenodd" />
                </svg>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    {compact && site.services.length > 6 && (
      <div class="mt-10 text-center" data-reveal>
        <a href="/services" class="inline-flex items-center gap-2 glass px-6 py-3 rounded-[var(--radius,1.25rem)] text-sm font-bold text-white hover:bg-white/10 transition-colors">
          View all {site.services.length} services
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
            <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
