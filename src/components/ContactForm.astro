---
// src/components/ContactForm.astro
//
// Posts to /api/inquiry (functions/api/inquiry.ts) — the unified Cloudflare
// Function that handles email via Resend for every client, and SMS via
// Twilio when site.features.smsForwarding is true. Do not wire this form
// to Formspree, Web3Forms, or any third-party form backend — see CLAUDE.md.
import { site } from "../config/site";
---

<form
  id="inquiry-form"
  action="/api/inquiry"
  method="POST"
  enctype="multipart/form-data"
  class="space-y-5 max-w-xl"
>
  <div>
    <label for="name" class="block text-sm font-medium text-slate-700 mb-1">Name *</label>
    <input
      type="text" id="name" name="name" required
      class="w-full rounded-2xl border-2 border-slate-200 px-4 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[var(--brand)] focus:border-transparent"
    />
  </div>

  <div class="grid sm:grid-cols-2 gap-5">
    <div>
      <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">Phone</label>
      <input
        type="tel" id="phone" name="phone"
        class="w-full rounded-2xl border-2 border-slate-200 px-4 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[var(--brand)] focus:border-transparent"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
      <input
        type="email" id="email" name="email"
        class="w-full rounded-2xl border-2 border-slate-200 px-4 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[var(--brand)] focus:border-transparent"
      />
    </div>
  </div>
  <p class="text-xs text-slate-500 -mt-3">Please provide at least a phone number or an email so we can get back to you.</p>

  <div>
    <label for="message" class="block text-sm font-medium text-slate-700 mb-1">How can we help? *</label>
    <textarea
      id="message" name="message" rows="4" required
      class="w-full rounded-2xl border-2 border-slate-200 px-4 py-2.5 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[var(--brand)] focus:border-transparent"
    ></textarea>
  </div>

  <div>
    <label for="photo" class="block text-sm font-medium text-slate-700 mb-1">
      Add a photo <span class="text-slate-400">(optional — helpful for quotes)</span>
    </label>
    <input
      type="file" id="photo" name="photo" accept="image/*"
      class="w-full text-sm text-slate-600 rounded-2xl border-2 border-slate-200 px-3 py-2 file:mr-3 file:rounded-full file:border-0 file:bg-slate-100 file:px-3 file:py-1.5 file:text-sm file:font-medium hover:file:bg-slate-200"
    />
    <p class="text-xs text-slate-500 mt-1">Max 5MB.</p>
  </div>

  <button
    type="submit"
    class="pop-shadow w-full sm:w-auto inline-flex items-center justify-center rounded-full text-white px-7 py-3 text-base font-bold transition-transform hover:-translate-y-0.5 disabled:opacity-50"
    style="background: linear-gradient(135deg, var(--brand-600), #ec4899);"
  >
    Send Request
  </button>

  <p id="inquiry-status" class="text-sm" role="status" aria-live="polite"></p>

  <p class="text-xs text-slate-500">
    Prefer to talk? Call us directly at{" "}
    <a href={`tel:${site.phone}`} class="text-[var(--brand)] font-medium">{site.phoneDisplay}</a>.
  </p>
</form>

<script>
  // Progressive enhancement: submit via fetch so the user gets inline
  // feedback instead of a full page reload, but the form still works
  // (via native POST + redirect) if JS fails to load.
  const MAX_PHOTO_BYTES = 5 * 1024 * 1024; // 5 MB — must match functions/api/inquiry.ts

  const form = document.getElementById("inquiry-form") as HTMLFormElement | null;
  const status = document.getElementById("inquiry-status");
  const photoInput = document.getElementById("photo") as HTMLInputElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!status) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    // Reject an oversized photo before spending the time/bandwidth to upload
    // it — the server enforces the same limit, but catching it client-side
    // gives instant feedback instead of a full round trip.
    const photo = photoInput?.files?.[0];
    if (photo && photo.size > MAX_PHOTO_BYTES) {
      status.textContent = "Photo is too large (max 5MB). Please choose a smaller file.";
      status.className = "text-sm text-red-600 font-medium";
      return;
    }

    if (submitBtn) submitBtn.disabled = true;
    status.textContent = "Sending...";
    status.className = "text-sm text-slate-500";

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
      });
      const data = (await res.json()) as { ok: boolean; error?: string };

      if (data.ok) {
        status.textContent = "Thanks! We received your request and will be in touch shortly.";
        status.className = "text-sm text-green-600 font-medium";
        form.reset();
      } else {
        status.textContent = data.error || "Something went wrong. Please call us directly.";
        status.className = "text-sm text-red-600 font-medium";
      }
    } catch {
      status.textContent = "Something went wrong. Please call us directly.";
      status.className = "text-sm text-red-600 font-medium";
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
