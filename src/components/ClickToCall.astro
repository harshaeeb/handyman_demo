---
// src/components/ClickToCall.astro — reusable mid-page phone CTA
import { site } from "../config/site";

interface Props {
  label?: string;
}
const { label = `Call ${site.phoneDisplay}` } = Astro.props;
---

<a
  href={`tel:${site.phone}`}
  class="cta-ping animate-gradient pop-shadow inline-flex items-center gap-2 px-6 py-3 rounded-full font-bold text-white text-sm"
  style="background: linear-gradient(135deg, var(--brand-600) 0%, var(--brand-500) 50%, #ec4899 100%);"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
    <path fill-rule="evenodd" d="M1.885.511a1.745 1.745 0 0 1 2.61.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511Z" clip-rule="evenodd" />
  </svg>
  {label}
</a>
