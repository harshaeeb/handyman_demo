---
// src/components/ReviewsWidget.astro — light testimonial section
import { site } from "../config/site";

const testimonials = site.testimonials ?? [];
const avatarColors = [
  "linear-gradient(135deg, #ea580c, #fb923c)",
  "linear-gradient(135deg, #7c3aed, #a78bfa)",
  "linear-gradient(135deg, #0284c7, #38bdf8)",
];
---

<section class="relative py-20 overflow-hidden bg-white border-t border-slate-200">
  <!-- Background accent -->
  <div class="pointer-events-none absolute top-1/2 left-1/4 w-96 h-96 rounded-full bg-[var(--brand-100)] opacity-40 blur-3xl" style="transform: translateY(-50%);" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12" data-reveal>
      <div>
        <span class="inline-block text-xs font-bold text-[var(--brand-600)] uppercase tracking-widest mb-3 bg-[var(--brand-50)] border border-[var(--brand-100)] rounded-full px-3 py-1">
          Real Reviews
        </span>
        <h2 class="text-3xl sm:text-4xl font-black text-slate-900">
          <span class="gradient-text">{site.googleRating}★</span> from {site.googleReviewCount}+ customers
        </h2>
      </div>
      <a
        href={site.googleReviewLink}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white border border-slate-200 shadow-sm inline-flex items-center gap-2 px-5 py-2.5 rounded-[var(--radius,1.25rem)] text-sm font-semibold text-slate-900 hover:bg-slate-50 transition-colors flex-shrink-0"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        See all reviews
      </a>
    </div>

    {testimonials.length > 0 ? (
      <div class="grid md:grid-cols-3 gap-5" data-reveal-stagger>
        {testimonials.map((t, i) => (
          <div class="bento-glow card-lift bg-white border border-slate-200 shadow-sm rounded-[var(--radius,1.25rem)] p-6 flex flex-col gap-4">
            <!-- Stars -->
            <div class="flex gap-0.5">
              {Array.from({length: t.rating ?? 5}).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" fill="currentColor" class="w-4 h-4 text-amber-400">
                  <path d="M5.47.31a.6.6 0 0 1 1.06 0l1.13 2.29 2.52.37a.6.6 0 0 1 .33 1.02L8.67 5.8l.43 2.52a.6.6 0 0 1-.87.63L6 7.74 3.77 8.95a.6.6 0 0 1-.87-.63l.43-2.52L1.49 3.99a.6.6 0 0 1 .33-1.02l2.52-.37L5.47.31Z"/>
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <p class="text-slate-600 text-sm leading-relaxed flex-1">&ldquo;{t.text}&rdquo;</p>

            <!-- Author -->
            <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
              <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold text-white flex-shrink-0"
                   style={`background: ${avatarColors[i % avatarColors.length]};`}>
                {t.name.charAt(0)}
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-900">{t.name}</p>
                {t.role && <p class="text-xs text-slate-400">{t.role}</p>}
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="bg-white border border-slate-200 shadow-sm rounded-[var(--radius,1.25rem)] p-10 text-center" data-reveal>
        <p class="text-5xl font-black gradient-text mb-2">{site.googleRating}★</p>
        <p class="text-slate-500 mb-6">Based on {site.googleReviewCount}+ Google reviews</p>
        <a href={site.googleReviewLink} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-[var(--radius,1.25rem)] font-bold text-white"
           style="background: linear-gradient(135deg, var(--brand-600), var(--brand-500));">
          Read Reviews on Google
        </a>
      </div>
    )}
  </div>
</section>
