---
// src/components/Hero.astro — Gen Z redesign: mesh-gradient bg, grain
// texture, animated headline/blobs/magnetic CTAs via the HeroAnimated
// island, service-area marquee. Content still comes entirely from site.ts.
import { site } from "../config/site";
import { resolveImage } from "../utils/resolveImage";
import TrustBar from "./TrustBar.astro";
import Marquee from "./Marquee.astro";
import HeroAnimated from "./react/HeroAnimated";

const heroImage = resolveImage(site.images?.hero);
const showTrustBar = site.theme?.showTrustBar !== false;
const eyebrow = site.heroEyebrow ?? `Serving ${site.serviceAreas.slice(0, 3).join(", ")} & nearby`;
const reviewPlatform = site.reviewPlatform ?? "Google";

const [taglineMain, taglineAccent] = site.tagline.includes("—")
  ? [site.tagline.split("—")[0]!.trim(), site.tagline.split("—")[1]?.trim()]
  : [site.tagline, undefined];
---

<section class="mesh-bg grain relative overflow-hidden" style="min-height: 92vh; display: flex; flex-direction: column; justify-content: center;">
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-20 sm:py-28 w-full">
    {heroImage ? (
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <HeroAnimated
          client:load
          eyebrow={eyebrow}
          taglineMain={taglineMain}
          taglineAccent={taglineAccent}
          city={site.city}
          reviewCount={site.googleReviewCount}
          rating={site.googleRating}
          phone={site.phone}
          phoneDisplay={site.phoneDisplay}
          yearsInBusiness={site.yearsInBusiness}
          servicesCount={site.services.length}
          reviewPlatform={reviewPlatform}
        />
        <div class="pop-shadow aspect-[4/3] rounded-[1.5rem] overflow-hidden">
          <img
            src={heroImage}
            alt={`${site.business} handyman team in ${site.city}, ${site.state}`}
            class="w-full h-full object-cover"
            width="800" height="600"
            fetchpriority="high"
          />
        </div>
      </div>
    ) : (
      <HeroAnimated
        client:load
        eyebrow={eyebrow}
        taglineMain={taglineMain}
        taglineAccent={taglineAccent}
        city={site.city}
        reviewCount={site.googleReviewCount}
        rating={site.googleRating}
        phone={site.phone}
        phoneDisplay={site.phoneDisplay}
        yearsInBusiness={site.yearsInBusiness}
        servicesCount={site.services.length}
        reviewPlatform={reviewPlatform}
      />
    )}
  </div>

  <div class="relative z-10">
    <Marquee items={site.serviceAreas.map((a) => `${a}, ${site.state}`)} />
  </div>

  <!-- Scroll hint -->
  <div class="relative z-10 flex justify-center pb-8 pt-4">
    <div class="flex flex-col items-center gap-1 opacity-40">
      <span class="text-xs text-slate-400 tracking-widest uppercase">Scroll</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4 text-slate-400 animate-bounce">
        <path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
      </svg>
    </div>
  </div>
</section>

{showTrustBar && <TrustBar />}
