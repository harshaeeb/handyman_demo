---
// src/pages/index.astro
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import WhyUs from "../components/WhyUs.astro";
import ReviewsWidget from "../components/ReviewsWidget.astro";
import { site } from "../config/site";

const title = `Handyman Services in ${site.city}, ${site.state} | ${site.business}`;
const description = `${site.business} — ${site.tagline}. ${site.services.slice(0,4).map(s => s.name).join(", ")} and more. ${site.yearsInBusiness}+ years, ${site.googleRating}★ rated. Call ${site.phoneDisplay} for same-day service.`;
---

<Base title={title} description={description}>
  <Hero />
  <ServicesGrid compact />
  <WhyUs />
  <ReviewsWidget />

  <!-- Booking teaser — the live/mockup calendar itself lives on its own
       page (/book) so it isn't double-loaded here; this section just
       drives traffic there. -->
  {site.features.booking && (
    <section class="py-16 mesh-bg grain">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center" data-reveal>
        <span class="sticker inline-block text-xs font-bold text-[var(--brand-600)] uppercase tracking-widest mb-3 bg-white border-2 border-[var(--brand-100)] rounded-full px-3 py-1">
          Book Online
        </span>
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-slate-900">Ready to <span class="gradient-text-loud">book an appointment</span>?</h2>
        <p class="mt-2 text-slate-600 max-w-xl mx-auto">Pick a service and a time that works for you — confirmed instantly, no back-and-forth.</p>
        <div class="mt-6">
          <a
            href="/book"
            class="pop-shadow inline-flex items-center gap-2 px-7 py-3.5 rounded-[1.5rem] font-bold text-white text-base"
            style="background: linear-gradient(135deg, var(--brand-600) 0%, var(--brand-500) 50%, #ec4899 100%);"
          >
            Book an Appointment
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
              <path fill-rule="evenodd" d="M2 8a.75.75 0 0 1 .75-.75h8.69L8.22 4.03a.75.75 0 0 1 1.06-1.06l4.5 4.5a.75.75 0 0 1 0 1.06l-4.5 4.5a.75.75 0 0 1-1.06-1.06l3.22-3.22H2.75A.75.75 0 0 1 2 8Z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}
</Base>
