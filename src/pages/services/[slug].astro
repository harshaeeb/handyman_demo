---
// src/pages/services/[slug].astro
import Base from "../../layouts/Base.astro";
import ClickToCall from "../../components/ClickToCall.astro";
import ContactForm from "../../components/ContactForm.astro";
import { site } from "../../config/site";
import { resolveImage } from "../../utils/resolveImage";

export function getStaticPaths() {
  return site.services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const title = `${service.name} in ${site.city}, ${site.state} | ${site.business}`;
const description = `Need ${service.name.toLowerCase()} in ${site.city}? ${service.shortDescription} Call ${site.phoneDisplay} — ${site.yearsInBusiness}+ years serving ${site.serviceAreas.slice(0,3).join(", ")}.`;
const serviceImage = resolveImage(service.image);
---

<Base title={title} description={description}>
  <!-- Dark page header -->
  <section class="relative py-16 hero-dark noise-overlay">
    <div class="orb orb-1" style="opacity:0.4;" aria-hidden="true"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6">
      <a href="/services" class="inline-flex items-center gap-1.5 text-xs text-white/40 hover:text-white/70 transition-colors mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3">
          <path fill-rule="evenodd" d="M14 8a.75.75 0 0 1-.75.75H4.56l3.22 3.22a.75.75 0 1 1-1.06 1.06l-4.5-4.5a.75.75 0 0 1 0-1.06l4.5-4.5a.75.75 0 0 1 1.06 1.06L4.56 7.25h8.69A.75.75 0 0 1 14 8Z" clip-rule="evenodd" />
        </svg>
        All Services
      </a>
      <p class="text-sm font-semibold text-[var(--brand-400)] mb-2">{site.business}</p>
      <h1 class="text-3xl sm:text-4xl font-black text-white">{service.name}</h1>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16" style="background: #0f0e0d;">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-12 items-start">
      <div data-reveal-stagger>
        <p class="text-lg text-white/70 leading-relaxed">{service.description}</p>
        <p class="mt-4 text-sm text-white/40">
          Serving {site.serviceAreas.join(", ")}.
        </p>
        <div class="mt-8">
          <ClickToCall label={`Call about ${service.name}`} />
        </div>
      </div>

      <div data-reveal>
        {serviceImage ? (
          <div class="aspect-[4/3] rounded-[var(--radius,1.25rem)] overflow-hidden ring-1 ring-white/10">
            <img
              src={serviceImage}
              alt={`${service.name} in ${site.city}, ${site.state}`}
              class="w-full h-full object-cover"
              width="640" height="480"
              fetchpriority="high"
            />
          </div>
        ) : (
          <div class="aspect-[4/3] rounded-[var(--radius,1.25rem)] flex items-center justify-center text-sm text-white/20" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);">
            [ {service.name} image goes here ]
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Quote form -->
  <section class="py-16 border-t" style="background: #0c0a09; border-color: rgba(255,255,255,0.05);">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-black text-white mb-6">Request a Quote</h2>
      <ContactForm />
    </div>
  </section>
</Base>
