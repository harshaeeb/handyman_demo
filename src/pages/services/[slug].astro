---
// src/pages/services/[slug].astro
import Base from "../../layouts/Base.astro";
import ClickToCall from "../../components/ClickToCall.astro";
import ContactForm from "../../components/ContactForm.astro";
import { site } from "../../config/site";
import { resolveImage } from "../../utils/resolveImage";

export function getStaticPaths() {
  return site.services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const title = `${service.name} in ${site.city}, ${site.state} | ${site.business}`;
const description = `Need ${service.name.toLowerCase()} in ${site.city}? ${service.shortDescription} Call ${site.phoneDisplay} — ${site.yearsInBusiness}+ years serving ${site.serviceAreas.slice(0,3).join(", ")}.`;
const serviceImage = resolveImage(service.image);
---

<Base title={title} description={description}>
  <!-- Page header -->
  <section class="relative overflow-hidden bg-gradient-to-b from-[var(--brand-50)] to-white border-b border-[var(--brand-100)]">
    <div class="pointer-events-none absolute -top-16 -right-16 w-64 h-64 rounded-full bg-[var(--brand-200)] opacity-30 blur-3xl" aria-hidden="true"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-12" data-reveal>
      <a href="/services" class="inline-flex items-center gap-1.5 text-xs text-slate-500 hover:text-[var(--brand-600)] transition-colors mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3">
          <path fill-rule="evenodd" d="M14 8a.75.75 0 0 1-.75.75H4.56l3.22 3.22a.75.75 0 1 1-1.06 1.06l-4.5-4.5a.75.75 0 0 1 0-1.06l4.5-4.5a.75.75 0 0 1 1.06 1.06L4.56 7.25h8.69A.75.75 0 0 1 14 8Z" clip-rule="evenodd" />
        </svg>
        All Services
      </a>
      <p class="text-sm font-semibold text-[var(--brand-600)] mb-2">{site.business}</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">{service.name}</h1>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-12 items-start">
      <div data-reveal-stagger>
        <p class="text-lg text-slate-600 leading-relaxed">{service.description}</p>
        <p class="mt-4 text-sm text-slate-400">
          Serving {site.serviceAreas.join(", ")}.
        </p>
        <div class="mt-8">
          <ClickToCall label={`Call about ${service.name}`} />
        </div>
      </div>

      <div data-reveal>
        {serviceImage ? (
          <div class="aspect-[4/3] rounded-[var(--radius,1.25rem)] overflow-hidden ring-1 ring-slate-200 shadow-xl shadow-[var(--brand-100)]">
            <img
              src={serviceImage}
              alt={`${service.name} in ${site.city}, ${site.state}`}
              class="w-full h-full object-cover"
              width="640" height="480"
              fetchpriority="high"
            />
          </div>
        ) : (
          <div class="aspect-[4/3] rounded-[var(--radius,1.25rem)] bg-gradient-to-br from-[var(--brand-50)] to-[var(--brand-100)] border border-[var(--brand-200)] flex items-center justify-center text-[var(--brand-400)] text-sm">
            [ {service.name} image goes here ]
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Quote form -->
  <section class="py-16 bg-slate-50 border-t border-slate-200">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Request a Quote</h2>
      <ContactForm />
    </div>
  </section>
</Base>
