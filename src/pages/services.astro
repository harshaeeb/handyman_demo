---
// src/pages/services.astro
import Base from "../layouts/Base.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import { site } from "../config/site";

const title = `Handyman Services in ${site.city}, ${site.state} | ${site.business}`;
const description = `${site.services.map(s => s.name).join(", ")} — serving ${site.serviceAreas.join(", ")}. Call ${site.phoneDisplay} for a free quote from ${site.business}.`;
---

<Base title={title} description={description}>
  <section class="relative py-16" style="background: #0c0a09;">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <span class="inline-block text-xs font-bold text-[var(--brand-400)] uppercase tracking-widest mb-3 border border-[var(--brand-800)] rounded-full px-3 py-1" style="background: rgba(234,88,12,0.1);">
        What We Do
      </span>
      <h1 class="text-3xl sm:text-4xl font-black text-white">Our Services</h1>
      <p class="mt-3 text-white/50">
        Serving {site.serviceAreas.join(", ")} for {site.yearsInBusiness}+ years.
      </p>
    </div>
  </section>
  <ServicesGrid hideHeading />
</Base>
