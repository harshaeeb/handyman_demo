---
// src/pages/services.astro
import Base from "../layouts/Base.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import { site } from "../config/site";

const title = `Handyman Services in ${site.city}, ${site.state} | ${site.business}`;
const description = `${site.services.map(s => s.name).join(", ")} — serving ${site.serviceAreas.join(", ")}. Call ${site.phoneDisplay} for a free quote from ${site.business}.`;
---

<Base title={title} description={description}>
  <section class="relative overflow-hidden bg-gradient-to-b from-[var(--brand-50)] to-white border-b border-[var(--brand-100)]">
    <div class="pointer-events-none absolute -top-16 -right-16 w-64 h-64 rounded-full bg-[var(--brand-200)] opacity-30 blur-3xl" aria-hidden="true"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-12 text-center" data-reveal>
      <span class="inline-block text-xs font-bold text-[var(--brand-600)] uppercase tracking-widest mb-3 bg-[var(--brand-50)] border border-[var(--brand-100)] rounded-full px-3 py-1">
        What We Do
      </span>
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">Our Services</h1>
      <p class="mt-3 text-slate-500">
        Serving {site.serviceAreas.join(", ")} for {site.yearsInBusiness}+ years.
      </p>
    </div>
  </section>
  <ServicesGrid hideHeading />
</Base>
