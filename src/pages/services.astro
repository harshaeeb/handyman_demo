---
// src/pages/services.astro
import Base from "../layouts/Base.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import { site } from "../config/site";

const title = `Handyman Services in ${site.city}, ${site.state} | ${site.business}`;
const description = `${site.services.map(s => s.name).join(", ")} — serving ${site.serviceAreas.join(", ")}. Call ${site.phoneDisplay} for a free quote from ${site.business}.`;
---

<Base title={title} description={description}>
  <section class="relative overflow-hidden mesh-bg grain border-b border-slate-900/5">
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-12 text-center" data-reveal>
      <span class="sticker inline-block text-xs font-bold text-[var(--brand-600)] uppercase tracking-widest mb-3 bg-white border-2 border-[var(--brand-100)] rounded-full px-3 py-1">
        What We Do
      </span>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-slate-900">Our <span class="gradient-text-loud">Services</span></h1>
      <p class="mt-3 text-slate-500">
        Serving {site.serviceAreas.join(", ")} for {site.yearsInBusiness}+ years.
      </p>
    </div>
  </section>
  <ServicesGrid hideHeading />
</Base>
