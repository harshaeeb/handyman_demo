---
// src/pages/gallery.astro — completed-work portfolio. Content is entirely
// driven by site.gallery (src/config/site.ts); this page has zero
// business-specific copy of its own so the template stays reusable for
// any service business, not just handyman work.
import Base from "../layouts/Base.astro";
import GalleryCarousel from "../components/GalleryCarousel.astro";
import ClickToCall from "../components/ClickToCall.astro";
import { site } from "../config/site";

const title = `Our Work | ${site.business}`;
const description = `See recent projects completed by ${site.business} in ${site.city}, ${site.state} and the surrounding area.`;
const items = site.gallery ?? [];
---

<Base title={title} description={description}>
  <!-- Page header -->
  <section class="relative overflow-hidden mesh-bg grain border-b border-slate-900/5">
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-12 text-center" data-reveal>
      <span class="sticker inline-block text-xs font-bold text-[var(--brand-600)] uppercase tracking-widest mb-3 bg-white border-2 border-[var(--brand-100)] rounded-full px-3 py-1">
        Our Work
      </span>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-slate-900">Recent <span class="gradient-text-loud">Projects</span></h1>
      <p class="mt-3 text-slate-600 max-w-xl mx-auto">
        A look at completed jobs in {site.city} and the surrounding area — swipe or use the arrows to browse.
      </p>
    </div>
  </section>

  <section class="py-8 sm:py-10 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      {items.length > 0 ? (
        <GalleryCarousel />
      ) : (
        <p class="text-center text-slate-500">Project photos coming soon — check back shortly.</p>
      )}
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="py-16 mesh-bg grain border-t border-slate-900/5">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center" data-reveal>
      <h2 class="font-display text-2xl sm:text-3xl font-bold text-slate-900">Like what you see?</h2>
      <p class="mt-2 text-slate-600">Get a free estimate on your next project.</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        <ClickToCall label={`Call ${site.phoneDisplay}`} />
        <a href="/contact" class="glass-light inline-flex items-center gap-2 px-6 py-3 rounded-full font-bold text-slate-900 text-sm border-2 border-slate-900/10">
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>
</Base>
