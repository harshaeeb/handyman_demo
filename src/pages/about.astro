---
// src/pages/about.astro
import Base from "../layouts/Base.astro";
import ClickToCall from "../components/ClickToCall.astro";
import { site } from "../config/site";
import { resolveImage } from "../utils/resolveImage";

const title = `About ${site.business} | ${site.city}, ${site.state}`;
const description = `${site.business} has served ${site.serviceAreas.join(", ")} for ${site.yearsInBusiness}+ years. Learn about our team and our approach.`;
const aboutImage = resolveImage(site.images?.about);
const reviewPlatform = site.reviewPlatform ?? "Google";
---

<Base title={title} description={description}>
  <!-- Page header with brand gradient -->
  <section class="relative overflow-hidden mesh-bg grain border-b border-slate-900/5">
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 py-12" data-reveal>
      <span class="sticker inline-block text-xs font-bold text-[var(--brand-600)] uppercase tracking-widest mb-3 bg-white border-2 border-[var(--brand-100)] rounded-full px-3 py-1">
        Our Story
      </span>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-slate-900">About <span class="gradient-text-loud">{site.business}</span></h1>
    </div>
  </section>

  <!-- Two-column content -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 grid md:grid-cols-2 gap-12 items-start">
    <div class="space-y-5 text-slate-600 leading-relaxed" data-reveal-stagger>
      <p class="text-lg text-slate-700 font-medium">
        {site.business} is a locally owned handyman company serving{" "}
        {site.serviceAreas.join(", ")}.
      </p>
      <p>
        Before picking up a toolbelt full-time, owner Travis spent 14 years
        teaching in Wylie ISD. These days he brings that same patience and
        attention to detail to fence and gate builds, tiling, appliance
        installs, and the everyday repairs homeowners keep putting off.
      </p>
      <p>
        We believe in straight answers and fair pricing — a free estimate
        before any work starts, no surprise fees, no upselling work you don't
        need. That approach has earned us{" "}
        {site.googleReviewCount}+ five-star reviews from neighbors right here
        in {site.city} and the surrounding area.
      </p>

      <!-- Trust stats row -->
      <div class="pt-4 grid grid-cols-2 gap-4">
        <div class="pop-shadow rounded-[1.25rem] bg-white border-2 border-[var(--brand-100)] p-4" data-tilt>
          <p class="font-display text-3xl font-bold text-[var(--brand-700)]">{site.googleRating}★</p>
          <p class="text-sm text-slate-500 mt-1">Average rating</p>
        </div>
        <div class="pop-shadow rounded-[1.25rem] bg-white border-2 border-amber-100 p-4" data-tilt>
          <p class="font-display text-3xl font-bold text-amber-600">{site.googleReviewCount}+</p>
          <p class="text-sm text-slate-500 mt-1">{reviewPlatform} reviews</p>
        </div>
      </div>

      <div class="pt-2">
        <ClickToCall />
      </div>
    </div>

    <!-- Image or placeholder -->
    <div data-reveal>
      {aboutImage ? (
        <div class="pop-shadow aspect-[4/3] rounded-[1.5rem] overflow-hidden">
          <img
            src={aboutImage}
            alt={`${site.business} team`}
            class="w-full h-full object-cover"
            width="640"
            height="480"
          />
        </div>
      ) : (
        <div class="pop-shadow aspect-[4/3] rounded-[1.5rem] bg-gradient-to-br from-[var(--brand-50)] to-[var(--brand-100)] border-2 border-[var(--brand-200)] flex items-center justify-center text-[var(--brand-400)] text-sm">
          [ About image goes here — see site.images.about ]
        </div>
      )}
    </div>
  </section>
</Base>
