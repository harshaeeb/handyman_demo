---
// src/pages/404.astro
import Base from "../layouts/Base.astro";
import ClickToCall from "../components/ClickToCall.astro";
import { site } from "../config/site";

const title = `Page Not Found | ${site.business}`;
const description = `The page you're looking for doesn't exist. Contact ${site.business} directly — we're happy to help.`;
---

<Base title={title} description={description}>
  <section class="max-w-2xl mx-auto px-4 sm:px-6 py-24 text-center">
    <p class="text-6xl font-bold text-[var(--brand)]">404</p>
    <h1 class="mt-4 text-2xl sm:text-3xl font-bold text-slate-900">Page not found</h1>
    <p class="mt-4 text-slate-600">
      Sorry, we couldn't find that page. Head back home or give us a call — we're always happy to help.
    </p>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/"
        class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 transition-colors"
      >
        &larr; Back to Home
      </a>
      <ClickToCall />
    </div>
  </section>
</Base>
