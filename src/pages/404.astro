---
// src/pages/404.astro
import Base from "../layouts/Base.astro";
import ClickToCall from "../components/ClickToCall.astro";
import { site } from "../config/site";

const title = `Page Not Found | ${site.business}`;
const description = `The page you're looking for doesn't exist. Contact ${site.business} directly — we're happy to help.`;
---

<Base title={title} description={description}>
  <section class="mesh-bg grain max-w-2xl mx-auto px-4 sm:px-6 py-24 text-center rounded-[1.5rem]">
    <p class="font-display text-6xl font-bold gradient-text-loud">404</p>
    <h1 class="font-display mt-4 text-2xl sm:text-3xl font-bold text-slate-900">Page not found</h1>
    <p class="mt-4 text-slate-600">
      Sorry, we couldn't find that page. Head back home or give us a call — we're always happy to help.
    </p>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/"
        class="pop-shadow inline-flex items-center justify-center rounded-full border-2 border-slate-900/10 bg-white px-6 py-3 text-sm font-bold text-slate-700 hover:-translate-y-0.5 transition-transform"
      >
        &larr; Back to Home
      </a>
      <ClickToCall />
    </div>
  </section>
</Base>
