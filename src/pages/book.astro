---
// src/pages/book.astro — dedicated booking screen, linked from the header
// CTA (all pages) and the homepage teaser. Renders the same BookingEmbed
// used on the homepage (real Cal.com embed once site.ts calLink is set,
// otherwise the design-mockup fallback), with hideHeading so this page's
// own <h1> is the only heading, not a duplicate h2 underneath it.
import Base from "../layouts/Base.astro";
import BookingEmbed from "../components/BookingEmbed.astro";
import ClickToCall from "../components/ClickToCall.astro";
import { site } from "../config/site";

const title = `Book an Appointment | ${site.business}`;
const description = `Schedule a handyman appointment with ${site.business} online — pick a time that works for you in ${site.city}, ${site.state}. Confirmed instantly.`;
---

<Base title={title} description={description}>
  <!-- Page header -->
  <section class="relative overflow-hidden mesh-bg grain border-b border-slate-900/5">
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-12 text-center" data-reveal>
      <span class="sticker inline-block text-xs font-bold text-[var(--brand-600)] uppercase tracking-widest mb-3 bg-white border-2 border-[var(--brand-100)] rounded-full px-3 py-1">
        Book Online
      </span>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-slate-900">Book an <span class="gradient-text-loud">Appointment</span></h1>
      <p class="mt-3 text-slate-600 max-w-xl mx-auto">
        Pick a service and a time that works for you — confirmed instantly. Have a bigger project in mind? Call us directly and we'll find the right slot.
      </p>
      <div class="mt-6 flex justify-center">
        <ClickToCall label={`Call ${site.phoneDisplay} instead`} />
      </div>
    </div>
  </section>

  {site.features.booking ? (
    <BookingEmbed hideHeading />
  ) : (
    <section class="py-16">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
        <p class="text-slate-600">
          Online booking isn't turned on for this site yet. Call us at{" "}
          <a href={`tel:${site.phone}`} class="font-bold text-[var(--brand-600)]">{site.phoneDisplay}</a>{" "}
          or <a href="/contact" class="font-bold text-[var(--brand-600)]">send a message</a> to schedule.
        </p>
      </div>
    </section>
  )}
</Base>
