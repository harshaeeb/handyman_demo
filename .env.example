# Copy this file's contents into the Cloudflare Pages project's
# Environment Variables settings (Settings > Environment variables).
# Never commit a real .env file — it's already in .gitignore.

# Required for every client (Resend transactional email)
RESEND_API_KEY=

# Optional: the client's verified sending address, e.g. inquiries@smithplumbing.com.
# Omit until the client's domain is verified in Resend — falls back to
# onboarding@resend.dev, which works without domain verification but only
# delivers to the Resend account's registered email.
RESEND_FROM_EMAIL=

# Required only if site.features.smsForwarding is true (Twilio SMS upsell)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
