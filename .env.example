# Copy this file's contents into the Cloudflare Pages project's
# Environment Variables settings (Settings > Environment variables).
# Never commit a real .env file — it's already in .gitignore.

# Required for every client (Resend transactional email)
RESEND_API_KEY=

# Required only if site.features.smsForwarding is true (Twilio SMS upsell)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
